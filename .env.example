EXPO_PUBLIC_RC_MALE_VITALITY_PRODUCT_IDS=male_sexual_health

# Set to true only for QA builds where purchase package mapping should be visible in native logs.
EXPO_PUBLIC_ENABLE_PURCHASE_QA_LOGS=false

# Set to true on dev/preview builds to allow screenshots and screen recording (store assets).
EXPO_PUBLIC_ALLOW_SCREEN_CAPTURE=false

# Set to true to show "Try the Free Detox Program" on the paywall (enabled in eas.json for EAS builds).
EXPO_PUBLIC_ENABLE_FREE_TIER_ENTRY=false

# Set to true to log local notification scheduling decisions in Metro/device logs.
EXPO_PUBLIC_ENABLE_NOTIFICATION_QA_LOGS=false

EXPO_PUBLIC_SUPABASE_PROGRAM_AUDIO_BUCKET=program-audio
EXPO_PUBLIC_EAS_PROJECT_ID=
EXPO_PUBLIC_RECOVERY_COMPASS_WEB_URL=https://recoverycompass.co
EXPO_PUBLIC_ENABLE_APP_WEB_HANDOFF=false
EXPO_PUBLIC_FORCE_MANDATORY_UPDATE_PREVIEW=false

# Supabase Edge Function / RevenueCat webhook environment
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
PUSH_FUNCTION_ADMIN_TOKEN=
