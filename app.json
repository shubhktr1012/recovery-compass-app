{
  "expo": {
    "name": "Recovery Compass",
    "slug": "recovery-compass-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": [
      "recoverycompassapp",
      "com.googleusercontent.apps.955627803414-jd1a0u09ak4gk8kb64jur99e3qrr96p3",
      "com.googleusercontent.apps.955627803414-7l9f9rt1shp0cndcmfa637plgri6d5dm"
    ],
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.recoverycompass.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.recoverycompass.app",
      "intentFilters": [
        {
          "action": "VIEW",
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ],
          "data": [
            {
              "scheme": "recoverycompassapp"
            }
          ]
        },
        {
          "action": "VIEW",
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ],
          "data": [
            {
              "scheme": "com.googleusercontent.apps.955627803414-jd1a0u09ak4gk8kb64jur99e3qrr96p3"
            }
          ]
        },
        {
          "action": "VIEW",
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ],
          "data": [
            {
              "scheme": "com.googleusercontent.apps.955627803414-7l9f9rt1shp0cndcmfa637plgri6d5dm"
            }
          ]
        }
      ],
      "permissions": [
        "com.android.vending.BILLING"
      ],
      "blockedPermissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#0B3B2E",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon-primary.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow $(PRODUCT_NAME) to access your photos",
          "cameraPermission": false,
          "microphonePermission": false
        }
      ],
      "expo-secure-store",
      "expo-apple-authentication",
      "expo-notifications",
      "@react-native-community/datetimepicker",
      [
        "expo-audio",
        {
          "enableBackgroundPlayback": true
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "releaseChannel": "production",
      "router": {},
      "eas": {
        "projectId": "aaa4fd59-057e-489b-aa97-8885e00d8394"
      }
    }
  }
}
