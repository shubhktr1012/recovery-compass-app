{
  "name": "recovery-compass-app",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "lint:strict": "./node_modules/.bin/eslint app components providers hooks lib constants --no-cache",
    "typecheck": "./node_modules/.bin/tsc --noEmit",
    "generate:program-content": "node ./scripts/generate-program-content.mjs",
    "canonical:normalize": "node ./scripts/normalize-program-content.mjs",
    "canonical:validate": "node ./scripts/validate-canonical-content.mjs",
    "canonical:qa": "node ./scripts/canonical-quality-check.mjs --exclude ninety_day_transform",
    "canonical:qa:all": "node ./scripts/canonical-quality-check.mjs",
    "canonical:seed": "node ./scripts/generate-program-seeds-from-canonical.mjs",
    "supabase:types:gen": "supabase gen types --linked --lang typescript --schema public > types/database.types.ts",
    "supabase:functions:list": "supabase functions list --workdir .",
    "supabase:functions:deploy:delete-account": "supabase functions deploy delete-account --no-verify-jwt --use-api --import-map ./supabase/functions/deno.json --workdir .",
    "supabase:functions:deploy:revenuecat-webhook": "supabase functions deploy revenuecat-webhook --no-verify-jwt --use-api --import-map ./supabase/functions/deno.json --workdir ."
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@gorhom/bottom-sheet": "^5.2.8",
    "@hookform/resolvers": "^5.2.2",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-native-community/netinfo": "11.4.1",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.1.8",
    "@supabase/supabase-js": "^2.95.3",
    "@tanstack/query-async-storage-persister": "^5.90.22",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-query-persist-client": "^5.90.22",
    "base64-arraybuffer": "^1.0.2",
    "clsx": "^2.1.1",
    "expo": "~54.0.33",
    "expo-apple-authentication": "~8.0.8",
    "expo-audio": "~1.1.1",
    "expo-auth-session": "~7.0.10",
    "expo-blur": "~15.0.8",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.8",
    "expo-dev-client": "~6.0.20",
    "expo-device": "~8.0.10",
    "expo-file-system": "~19.0.21",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-image-picker": "~17.0.10",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-notifications": "~0.32.16",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-web-browser": "~15.0.10",
    "jose": "^6.2.2",
    "nativewind": "^4.2.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.71.1",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-pager-view": "6.9.1",
    "react-native-purchases": "^9.10.3",
    "react-native-purchases-ui": "^9.10.3",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^3.4.19",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~10.0.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
